{
  "name": "frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve govos-admin",
    "start:admin": "ng serve govos-admin",
    "start:citizen": "ng serve govos-citizen",
    "start:officer": "ng serve govos-officer",
    "start:collector": "ng serve govos-collector",
    "build": "ng build govos-admin",
    "build:all": "ng build govos-admin && ng build govos-citizen && ng build govos-officer && ng build govos-collector",
    "generate:api": "openapi-generator-cli generate -g typescript-angular -i openapi/govos-api.yaml -o projects/shared-api/src/lib/generated --additional-properties=ngVersion=20.0.0,providedInRoot=true,supportsES6=true,withInterfaces=true,stringEnums=true,serviceSuffix=ApiService,modelPropertyNaming=original",
    "watch": "ng build govos-admin --watch --configuration development",
    "test": "ng test"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.3.26",
    "@angular/cdk": "^20.2.14",
    "@angular/common": "^20.3.0",
    "@angular/compiler": "^20.3.0",
    "@angular/core": "^20.3.0",
    "@angular/forms": "^20.3.0",
    "@angular/material": "^20.2.14",
    "@angular/platform-browser": "^20.3.0",
    "@angular/router": "^20.3.0",
    "@ngx-translate/core": "^16.0.4",
    "@ngx-translate/http-loader": "^16.0.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^20.3.32",
    "@angular/cli": "^20.3.32",
    "@angular/compiler-cli": "^20.3.0",
    "@openapitools/openapi-generator-cli": "^2.35.0",
    "@types/jasmine": "~5.1.0",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ng-packagr": "^20.3.0",
    "typescript": "~5.9.2"
  }
}
